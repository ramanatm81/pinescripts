//@version=6
indicator("V-Shape Pattern", overlay=true, max_labels_count=500, max_lines_count=500)

//=============================
// Inputs
//=============================
lookback    = input.int(10,    "Lookback (bars each side)", minval=2, maxval=50)
minLeg      = input.float(10.0, "Min leg size (points)",   minval=0.5, step=0.5)
wickPct     = input.float(50.0, "Max Wick (% of body)",    minval=10.0, maxval=300.0, step=10.0)
showEnds    = input.bool(true,  "Show leg endpoints",       group="Display")
showPivot   = input.bool(true,  "Show pivot label",         group="Display")
showLines   = input.bool(true,  "Show V lines",             group="Display")

//=============================
// Wick filter
//=============================
wickOk(b) =>
    b_body  = math.abs(close[b] - open[b])
    b_upper = high[b] - math.max(open[b], close[b])
    b_lower = math.min(open[b], close[b]) - low[b]
    lim     = b_body * (wickPct / 100.0)
    b_upper <= lim and b_lower <= lim

//=============================
// V-Shape (bullish)
// Timeline: [leftEnd] ... [pivot=lookback bars ago] ... [now]
// ta.highestbars(high, lookback+1) scans bars [0..lookback] from current
// It returns a negative offset from current bar, e.g. -8 means 8 bars ago
// The pivot is at offset -lookback from current
// Left end must be between offset -lookback and 0 from current, i.e. to LEFT of pivot
// Wait — ta.highestbars searches the FULL lookback+1 window ending at current bar
// We want highest only on the LEFT side of pivot, i.e. bars [lookback .. 2*lookback] from current
//=============================
lowestInWindow = ta.lowest(low, 2 * lookback + 1)
isVPivot       = low[lookback] == lowestInWindow and wickOk(lookback)

pivotLow = low[lookback]

// Search for left-leg high only in the LEFT half: bars lookback..2*lookback from current
// Use offset arithmetic: look at bars [lookback..2*lookback] ago
leftHighVal = high[lookback]
leftHighOff = lookback  // offset from current bar (will find the max)
for i = lookback to 2 * lookback
    if high[i] > leftHighVal
        leftHighVal := high[i]
        leftHighOff := i

// Right leg end is current bar
rightLeg = close - pivotLow
leftLeg  = leftHighVal - pivotLow

isV = isVPivot and leftLeg >= minLeg and rightLeg >= minLeg

var int vCount = 0
if isV
    vCount += 1
    leftEndIdx  = bar_index - leftHighOff   // actual bar_index of left end
    pivotIdx    = bar_index - lookback
    rightEndIdx = bar_index

    if showPivot and not showEnds
        label.new(pivotIdx, low[lookback],
                  text      = "V" + str.tostring(vCount),
                  style     = label.style_label_up,
                  color     = color.new(color.green, 10),
                  textcolor = color.white,
                  size      = size.normal)

    if showEnds
        label.new(leftEndIdx, high[leftHighOff],
                  text      = "V" + str.tostring(vCount) + " ●\n" + str.tostring(high[leftHighOff], "#.##"),
                  style     = label.style_label_down,
                  color     = color.new(color.green, 30),
                  textcolor = color.white,
                  size      = size.small)
        label.new(pivotIdx, low[lookback],
                  text      = "V" + str.tostring(vCount) + " ▼\n" + str.tostring(low[lookback], "#.##"),
                  style     = label.style_label_up,
                  color     = color.new(color.green, 10),
                  textcolor = color.white,
                  size      = size.small)
        label.new(rightEndIdx, close,
                  text      = "V" + str.tostring(vCount) + " ◆\n" + str.tostring(close, "#.##"),
                  style     = label.style_label_up,
                  color     = color.new(color.green, 30),
                  textcolor = color.white,
                  size      = size.small)

    if showLines
        line.new(leftEndIdx, high[leftHighOff], pivotIdx, low[lookback],
                 color = color.new(color.green, 20), width = 1)
        line.new(pivotIdx, low[lookback], rightEndIdx, close,
                 color = color.new(color.green, 20), width = 1)

//=============================
// Reverse-V (bearish)
//=============================
highestInWindow = ta.highest(high, 2 * lookback + 1)
isRevVPivot     = high[lookback] == highestInWindow and wickOk(lookback)

pivotHigh = high[lookback]

leftLowVal = low[lookback]
leftLowOff = lookback
for i = lookback to 2 * lookback
    if low[i] < leftLowVal
        leftLowVal := low[i]
        leftLowOff := i

rightLegRev = pivotHigh - close
leftLegRev  = pivotHigh - leftLowVal

isRevV = isRevVPivot and leftLegRev >= minLeg and rightLegRev >= minLeg

var int revVCount = 0
if isRevV
    revVCount += 1
    leftEndIdxR  = bar_index - leftLowOff
    pivotIdxR    = bar_index - lookback
    rightEndIdxR = bar_index

    if showPivot and not showEnds
        label.new(pivotIdxR, high[lookback],
                  text      = "R" + str.tostring(revVCount),
                  style     = label.style_label_down,
                  color     = color.new(color.red, 10),
                  textcolor = color.white,
                  size      = size.normal)

    if showEnds
        label.new(leftEndIdxR, low[leftLowOff],
                  text      = "R" + str.tostring(revVCount) + " ●\n" + str.tostring(low[leftLowOff], "#.##"),
                  style     = label.style_label_up,
                  color     = color.new(color.red, 30),
                  textcolor = color.white,
                  size      = size.small)
        label.new(pivotIdxR, high[lookback],
                  text      = "R" + str.tostring(revVCount) + " ▲\n" + str.tostring(high[lookback], "#.##"),
                  style     = label.style_label_down,
                  color     = color.new(color.red, 10),
                  textcolor = color.white,
                  size      = size.small)
        label.new(rightEndIdxR, close,
                  text      = "R" + str.tostring(revVCount) + " ◆\n" + str.tostring(close, "#.##"),
                  style     = label.style_label_down,
                  color     = color.new(color.red, 30),
                  textcolor = color.white,
                  size      = size.small)

    if showLines
        line.new(leftEndIdxR, low[leftLowOff], pivotIdxR, high[lookback],
                 color = color.new(color.red, 20), width = 1)
        line.new(pivotIdxR, high[lookback], rightEndIdxR, close,
                 color = color.new(color.red, 20), width = 1)

//=============================
// Alerts
//=============================
if isV
    alert("V-Shape — bullish pivot at " + str.tostring(low[lookback]), alert.freq_once_per_bar)
if isRevV
    alert("Reverse-V — bearish pivot at " + str.tostring(high[lookback]), alert.freq_once_per_bar)