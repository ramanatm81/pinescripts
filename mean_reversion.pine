//@version=6
indicator("Mean Reversion Ladder", overlay=true, max_lines_count=500, max_labels_count=500)

//=============================
// Inputs
//=============================
thresholdPtsETH = input.float(50,     "Impulse Threshold - ETH (points)")
thresholdPtsRTH = input.float(30,     "Impulse Threshold - RTH (points)")
showMarkers     = input.bool(true,    "Show Markers")
showLines       = input.bool(true,    "Connect Anchors")
showLevels      = input.bool(false,   "Show Level Labels")
loiterMins      = input.int(90,       "Loiter Reset (min, 0=off)", minval=0)
fastImpulseMins = input.int(7,        "Directional Threshold (min) — impulses faster than this", minval=1)
slowImpulseMins = input.int(20,       "Range Bound / Reversal Threshold (min)",                  minval=1)
contCandles     = input.int(10,       "Continuation — candles after extension with no half-reversal", minval=1)

//=============================
// Time helpers (all exchange timezone)
//=============================
ETH_MINS  = 17 * 60       // 17:00 — ETH session reset
MO_MINS   = 9  * 60 + 30  // 09:30 — market open / RTH start
SKIP_MINS = 8  * 60 + 30  // 08:30 — skip window start

curMins  = hour(time, syminfo.timezone) * 60 + minute(time, syminfo.timezone)
prevMins = hour(time[1], syminfo.timezone) * 60 + minute(time[1], syminfo.timezone)

crossedETH   = curMins == ETH_MINS and prevMins != ETH_MINS
crossedMO    = curMins == MO_MINS  and prevMins != MO_MINS
sessionReset = crossedETH or crossedMO

inSkipWindow = curMins >= SKIP_MINS and curMins < MO_MINS

// RTH: market open → ETH reset; everything else uses ETH threshold
inRTH           = curMins >= MO_MINS and curMins < ETH_MINS
activeThreshold = inRTH ? thresholdPtsRTH : thresholdPtsETH

//=============================
// State
//=============================
var float anchor       = na     // current anchor price
var bool  inImpulse    = false
var float impulseDist  = na     // signed: +up / -down
var float impulsePrice = na     // close at impulse detection bar

// For connecting lines between anchor events
var float prevAnchPrice  = na
var int   prevAnchBi     = na
var bool  reversionFired = false
var int   extCount       = 0   // extended anchors
var int   normCount      = 0   // resets + reversions
var label liveLabel      = na
var int   impulseTime    = na  // Unix ms timestamp when last impulse fired
var int   anchorSetTime  = na  // Unix ms timestamp when anchor was last placed

// Alert flags — non-var, reset to false every bar, set true when event fires
bool alertImpulseUp   = false
bool alertImpulseDown = false
bool alertExtension   = false
bool alertReversion   = false
bool alertLoiter      = false

// Impulse cadence tracking
var int   prevImpulseTime = na  // timestamp of last event (for elapsed display)
var int   lastGapMs       = na  // ms between last two impulses

// Reversal detection: two same-direction impulses within slowImpulseMins
var int    lastImpDir     = 0   // direction of last impulse: 1=up, -1=down
var int    lastImpTime    = na  // timestamp of last impulse
var bool   reversalActive = false
var string lastStatus     = "WAITING"  // sticky status — only changes on event

// Continuation tracking: after extension, watch for half-threshold reversal
var bool  trackCont    = false  // actively watching for continuation
var int   extBarIdx    = na     // bar_index when extension fired
var float extPrice     = na     // price at extension (new anchor)
var int   extDir       = 0      // direction of extension: 1=up, -1=down
var float extThresh    = na     // threshold captured at extension time
bool      alertCont        = false  // non-var: fires on continuation event
bool      alertDirectional = false  // non-var: fires when event within slowImpulseMins/4

//=============================
// Session reset — ETH (blue) or market open (yellow)
//=============================
if sessionReset
    col           = crossedETH ? color.new(color.blue, 0) : color.new(color.yellow, 0)
    anchor          := open
    inImpulse       := false
    impulseDist     := na
    impulsePrice    := na
    prevAnchPrice   := open
    prevAnchBi      := bar_index
    reversionFired  := false
    impulseTime     := na
    anchorSetTime   := time
    normCount       += 1
    prevImpulseTime := na
    lastGapMs       := na
    lastImpDir      := 0
    lastImpTime     := na
    reversalActive  := false
    lastStatus      := "WAITING"
    trackCont       := false
    extBarIdx       := na
    extPrice        := na
    extDir          := 0
    extThresh       := na
    if showMarkers
        label.new(bar_index, open, text="", style=label.style_circle, size=size.small, color=col)
    if showLevels
        label.new(bar_index, open,
                  text      = str.tostring(open, "#.##"),
                  style     = label.style_label_down,
                  size      = size.small,
                  color     = col,
                  textcolor = crossedETH ? color.white : color.black)

//=============================
// Main logic — only runs after anchor set, outside skip window, not on reset bar
//=============================
if not na(anchor) and not inSkipWindow and not sessionReset

    if not inImpulse
        //--------------------------------------------------
        // Loiter reset: anchor idle > loiterMins with no impulse
        //--------------------------------------------------
        loitered = loiterMins > 0 and not na(anchorSetTime) and
                   (time - anchorSetTime) >= loiterMins * 60000
        if loitered
            alertLoiter := true
            if showLines
                line.new(prevAnchBi, prevAnchPrice, bar_index, close,
                         width=1, color=color.orange, style=line.style_dashed)
            if showMarkers
                label.new(bar_index, close, text="", style=label.style_circle,
                          size=size.small, color=color.new(color.orange, 0))
            anchor          := close
            anchorSetTime   := time
            prevAnchPrice   := close
            prevAnchBi      := bar_index
            normCount       += 1
            prevImpulseTime := time  // cadence: next impulse gap measured from loiter anchor

        //--------------------------------------------------
        // Step 1: Detect impulse using high/low (intrabar breach counts)
        //--------------------------------------------------
        upDist   = high - anchor
        downDist = anchor - low

        isUp   = upDist   >= activeThreshold
        isDown = downDist >= activeThreshold

        // If both breach (large-range bar), take whichever side traveled further
        takeUp   = isUp   and (not isDown or upDist >= downDist)
        takeDown = isDown and not takeUp

        // Time since anchor was last set (for impulse label)
        anchElapsedMins = not na(anchorSetTime) ? math.round((time - anchorSetTime) / 60000) : 0
        anchElHr        = math.floor(anchElapsedMins / 60)
        anchElMn        = anchElapsedMins - anchElHr * 60
        anchElStr       = not na(anchorSetTime)
                           ? (anchElapsedMins >= 60
                              ? str.tostring(anchElHr, "#") + "h " + str.tostring(anchElMn, "#") + "m"
                              : str.tostring(anchElapsedMins, "#") + "m")
                           : ""

        if takeUp
            alertImpulseUp := true
            inImpulse      := true
            impulseDist    := upDist          // positive
            impulsePrice   := high
            impulseTime    := time
            reversionFired := false
            if showMarkers
                label.new(bar_index, high,
                          text      = anchElStr,
                          style     = label.style_label_down,
                          size      = size.small,
                          color     = color.new(color.green, 0),
                          textcolor = color.white)
            if showLevels
                label.new(bar_index, high,
                          text      = str.tostring(high, "#.##"),
                          style     = label.style_label_up,
                          size      = size.small,
                          color     = color.new(color.green, 0),
                          textcolor = color.white)

        else if takeDown
            alertImpulseDown := true
            inImpulse        := true
            impulseDist    := low - anchor    // negative
            impulsePrice   := low
            impulseTime    := time
            reversionFired := false
            if showMarkers
                label.new(bar_index, low,
                          text      = anchElStr,
                          style     = label.style_label_up,
                          size      = size.small,
                          color     = color.new(color.red, 0),
                          textcolor = color.white)
            if showLevels
                label.new(bar_index, low,
                          text      = str.tostring(low, "#.##"),
                          style     = label.style_label_down,
                          size      = size.small,
                          color     = color.new(color.red, 0),
                          textcolor = color.white)

    else
        //--------------------------------------------------
        // Step 2a: Extension — another threshold in same direction from impulse price
        //--------------------------------------------------
        extended = impulseDist > 0
                   ? high >= impulsePrice + activeThreshold
                   : low  <= impulsePrice - activeThreshold

        if extended
            extCandleBody  = math.abs(close - open)
            strongContinuation = extCandleBody >= activeThreshold * 2 / 3

            if strongContinuation
                // Big-body extension candle — treat as Continuation, not Extension
                alertCont := true
                if showMarkers
                    label.new(bar_index, impulseDist > 0 ? high : low,
                              text      = "CONT",
                              style     = impulseDist > 0 ? label.style_label_down : label.style_label_up,
                              size      = size.small,
                              color     = color.new(color.teal, 0),
                              textcolor = color.white)
            else
                alertExtension := true
                extTimeMins = not na(impulseTime) ? math.round((time - impulseTime) / 60000) : 0
                extHrPart   = math.floor(extTimeMins / 60)
                extMnPart   = extTimeMins - extHrPart * 60
                extTimeStr  = not na(impulseTime)
                               ? (extTimeMins >= 60
                                  ? str.tostring(extHrPart, "#") + "h " + str.tostring(extMnPart, "#") + "m"
                                  : str.tostring(extTimeMins, "#") + "m")
                               : ""
                if showLines
                    line.new(prevAnchBi, prevAnchPrice, bar_index, close, width=2, color=color.purple)
                if showMarkers
                    label.new(bar_index, close, text="", style=label.style_circle, size=size.small,
                              color=color.new(color.purple, 0))
                    label.new(bar_index, close,
                              text  = "EXT\n" + str.tostring(close, "#.##") + (not na(impulseTime) ? "\n" + extTimeStr : ""),
                              style = impulseDist > 0 ? label.style_label_down : label.style_label_up,
                              size  = size.small,
                              color = color.new(color.purple, 0),
                              textcolor = color.white)

            // Start continuation watch — capture direction before clearing impulseDist
            trackCont  := true
            extBarIdx  := bar_index
            extPrice   := close
            extDir     := impulseDist > 0 ? 1 : -1
            extThresh  := activeThreshold

            anchor         := close
            anchorSetTime  := time
            prevAnchPrice  := close
            prevAnchBi     := bar_index
            inImpulse      := false
            impulseDist    := na
            impulsePrice   := na
            impulseTime    := na
            reversionFired := false
            extCount       += 1

        else
            //--------------------------------------------------
            // Step 2b: Reversion — wick touched anchor (marker only, cycle continues)
            //--------------------------------------------------
            reverted = impulseDist > 0 ? low <= anchor : high >= anchor
            if reverted and not reversionFired
                alertReversion := true
                revTimeMins = not na(impulseTime) ? math.round((time - impulseTime) / 60000) : 0
                revHrPart   = math.floor(revTimeMins / 60)
                revMnPart   = revTimeMins - revHrPart * 60
                revTimeStr  = not na(impulseTime)
                               ? (revTimeMins >= 60
                                  ? str.tostring(revHrPart, "#") + "h " + str.tostring(revMnPart, "#") + "m"
                                  : str.tostring(revTimeMins, "#") + "m")
                               : ""
                if showLines
                    line.new(prevAnchBi, prevAnchPrice, bar_index, close, width=2, color=color.fuchsia)
                if showMarkers
                    label.new(bar_index, close, text="", style=label.style_circle, size=size.small,
                              color=color.new(color.fuchsia, 0))
                    label.new(bar_index, close,
                              text      = revTimeStr,
                              style     = impulseDist > 0 ? label.style_label_down : label.style_label_up,
                              size      = size.small,
                              color     = color.new(color.fuchsia, 60),
                              textcolor = color.white)
                if showLevels
                    label.new(bar_index, close,
                              text      = str.tostring(close, "#.##"),
                              style     = impulseDist > 0 ? label.style_label_up : label.style_label_down,
                              size      = size.small,
                              color     = color.new(color.fuchsia, 0),
                              textcolor = color.white)
                // Marker only — do NOT reset inImpulse; extension can still fire
                prevAnchPrice   := close
                prevAnchBi      := bar_index
                reversionFired  := true
                normCount       += 1
                prevImpulseTime := time  // cadence + re-impulse label timing measured from here

            else if reversionFired
                //--------------------------------------------------
                // Step 2c: After reversion, detect impulse in either direction
                // Opposite direction: new impulse cycle
                // Same direction: re-impulse — reset impulsePrice so extension
                //                 is measured from the new breach point
                //--------------------------------------------------
                oppDown  = impulseDist > 0 and anchor - low  >= activeThreshold
                oppUp    = impulseDist < 0 and high - anchor >= activeThreshold
                sameUp   = impulseDist > 0 and high - anchor >= activeThreshold
                sameDown = impulseDist < 0 and anchor - low  >= activeThreshold

                // Time since reversion (prevImpulseTime set at reversion)
                reAnchMins = not na(prevImpulseTime) ? math.round((time - prevImpulseTime) / 60000) : 0
                reAnchHr   = math.floor(reAnchMins / 60)
                reAnchMn   = reAnchMins - reAnchHr * 60
                reAnchStr  = not na(prevImpulseTime)
                              ? (reAnchMins >= 60
                                 ? str.tostring(reAnchHr, "#") + "h " + str.tostring(reAnchMn, "#") + "m"
                                 : str.tostring(reAnchMins, "#") + "m")
                              : ""

                if oppDown
                    alertImpulseDown := true
                    inImpulse      := true
                    impulseDist    := low - anchor    // negative
                    impulsePrice   := low
                    impulseTime    := time
                    reversionFired := false
                    if showMarkers
                        label.new(bar_index, low,
                                  text      = reAnchStr,
                                  style     = label.style_label_up,
                                  size      = size.small,
                                  color     = color.new(color.red, 0),
                                  textcolor = color.white)
                    if showLevels
                        label.new(bar_index, low,
                                  text      = str.tostring(low, "#.##"),
                                  style     = label.style_label_down,
                                  size      = size.small,
                                  color     = color.new(color.red, 0),
                                  textcolor = color.white)

                else if oppUp
                    alertImpulseUp := true
                    inImpulse      := true
                    impulseDist    := high - anchor   // positive
                    impulsePrice   := high
                    impulseTime    := time
                    reversionFired := false
                    if showMarkers
                        label.new(bar_index, high,
                                  text      = reAnchStr,
                                  style     = label.style_label_down,
                                  size      = size.small,
                                  color     = color.new(color.green, 0),
                                  textcolor = color.white)
                    if showLevels
                        label.new(bar_index, high,
                                  text      = str.tostring(high, "#.##"),
                                  style     = label.style_label_up,
                                  size      = size.small,
                                  color     = color.new(color.green, 0),
                                  textcolor = color.white)

                else if sameUp
                    alertImpulseUp := true
                    // inImpulse stays true; reset impulsePrice to the new breach point
                    impulseDist    := high - anchor
                    impulsePrice   := high
                    impulseTime    := time
                    reversionFired := false
                    if showMarkers
                        label.new(bar_index, high,
                                  text      = reAnchStr,
                                  style     = label.style_label_down,
                                  size      = size.small,
                                  color     = color.new(color.green, 0),
                                  textcolor = color.white)
                    if showLevels
                        label.new(bar_index, high,
                                  text      = str.tostring(high, "#.##"),
                                  style     = label.style_label_up,
                                  size      = size.small,
                                  color     = color.new(color.green, 0),
                                  textcolor = color.white)

                else if sameDown
                    alertImpulseDown := true
                    impulseDist    := low - anchor
                    impulsePrice   := low
                    impulseTime    := time
                    reversionFired := false
                    if showMarkers
                        label.new(bar_index, low,
                                  text      = reAnchStr,
                                  style     = label.style_label_up,
                                  size      = size.small,
                                  color     = color.new(color.red, 0),
                                  textcolor = color.white)
                    if showLevels
                        label.new(bar_index, low,
                                  text      = str.tostring(low, "#.##"),
                                  style     = label.style_label_down,
                                  size      = size.small,
                                  color     = color.new(color.red, 0),
                                  textcolor = color.white)

//=============================
// Continuation check — after extension, no half-reversal within contCandles
// Skip the extension bar itself (bar_index > extBarIdx)
//=============================
if trackCont and not na(extBarIdx) and not sessionReset and bar_index > extBarIdx
    halfThresh = extThresh / 2
    revHalf    = extDir == 1 ? close <= extPrice - halfThresh : close >= extPrice + halfThresh
    if revHalf
        trackCont := false  // reversed enough — no continuation
    else if bar_index - extBarIdx >= contCandles
        // Only fire if price is still diverging (at or beyond the extension price)
        stillDiverging = extDir == 1 ? close >= extPrice : close <= extPrice
        if stillDiverging
            alertCont := true
            if showMarkers
                label.new(bar_index, extDir == 1 ? high : low,
                          text      = "CONT",
                          style     = extDir == 1 ? label.style_label_down : label.style_label_up,
                          size      = size.small,
                          color     = color.new(color.teal, 0),
                          textcolor = color.white)
        trackCont := false

//=============================
// Impulse cadence — update on every new impulse/extension/reversion
//=============================
if alertImpulseUp or alertImpulseDown or alertExtension
    if not na(prevImpulseTime)
        lastGapMs := time - prevImpulseTime
        if lastGapMs <= (slowImpulseMins * 60000) / 4
            alertDirectional := true
    prevImpulseTime := time

// Reversal detection — only on directional impulses (not extensions)
// Two impulses in the same direction within slowImpulseMins = reversal
if alertImpulseUp or alertImpulseDown
    newDir    = alertImpulseUp ? 1 : -1
    gapToLast = not na(lastImpTime) ? time - lastImpTime : na
    if not na(lastImpTime) and newDir == lastImpDir and gapToLast <= slowImpulseMins * 60000
        reversalActive := true
        lastStatus     := "REVERSAL"
    else
        reversalActive := false
        // DIRECTIONAL if gap to previous event was fast, else TRENDING
        elSincePrev = not na(prevImpulseTime) ? math.round((time - prevImpulseTime) / 60000) : 999
        lastStatus  := elSincePrev < fastImpulseMins ? "DIRECTIONAL" : "TRENDING"
    lastImpDir  := newDir
    lastImpTime := time

//=============================
// Alerts
//=============================
anchorStr = not na(anchor) ? " | Anchor: " + str.tostring(anchor, "#.##") : ""

alertcondition(crossedETH,      title="Session Reset (ETH)",       message="Mean Reversion: ETH session reset{{anchorStr}}")
alertcondition(crossedMO,       title="Session Reset (Mkt Open)",  message="Mean Reversion: Market open session reset{{anchorStr}}")
alertcondition(alertLoiter,     title="Loiter Reset",               message="Mean Reversion: Anchor loiter reset — new anchor: {{close}}")
alertcondition(alertImpulseUp,  title="Impulse Up",                 message="Mean Reversion: Impulse UP fired | Price: {{high}} | Anchor: {{close}}")
alertcondition(alertImpulseDown,title="Impulse Down",               message="Mean Reversion: Impulse DOWN fired | Price: {{low}} | Anchor: {{close}}")
alertcondition(alertExtension,  title="Extension",                  message="Mean Reversion: EXTENSION — impulse continued | Price: {{close}}")
alertcondition(alertReversion,  title="Reversion",                  message="Mean Reversion: REVERSION to anchor | Price: {{close}}")
alertcondition(alertImpulseUp   or alertImpulseDown, title="Any Impulse",      message="Mean Reversion: Impulse fired | Price: {{close}}")
alertcondition(alertCont,                           title="Continuation",        message="Mean Reversion: CONTINUATION — no half-reversal after extension | Price: {{close}}")
alertcondition(alertDirectional,                    title="Directional",          message="Mean Reversion: DIRECTIONAL — impulse/extension within 1/4 range bound window | Price: {{close}}")

//=============================
// Live anchor distance label (current bar)
//=============================
if barstate.islast and not na(anchor)
    dist      = close - anchor
    absDist   = math.abs(dist)
    remaining = activeThreshold - absDist
    dirStr    = dist >= 0 ? "▲" : "▼"
    line1     = "Anchor " + str.tostring(anchor, "#.##") + "  |  " + dirStr + " " + str.tostring(math.round(absDist * 10) / 10, "#.#") + " pts"
    line2     = inImpulse
                 ? "Impulse active " + (impulseDist > 0 ? "↑" : "↓")
                 : (remaining > 0
                    ? str.tostring(math.round(remaining * 10) / 10, "#.#") + " pts to impulse"
                    : "Threshold reached")
    impDistStr = not na(impulsePrice)
                  ? "\nFrom impulse pt " + str.tostring(impulsePrice, "#.##") + "  |  " + (close >= impulsePrice ? "▲" : "▼") + " " + str.tostring(math.round(math.abs(close - impulsePrice) * 10) / 10, "#.#") + " pts"
                  : ""
    liveMins   = not na(impulseTime) ? math.round((time - impulseTime) / 60000) : 0
    liveHrPart = math.floor(liveMins / 60)
    liveMnPart = liveMins - liveHrPart * 60
    liveTimeStr = not na(impulseTime)
                   ? "\n" + (liveMins >= 60
                      ? str.tostring(liveHrPart, "#") + "h " + str.tostring(liveMnPart, "#") + "m since impulse"
                      : str.tostring(liveMins, "#") + "m since impulse")
                   : ""
    labelTxt  = line1 + "\n" + line2 + impDistStr + liveTimeStr
    if na(liveLabel)
        liveLabel := label.new(bar_index, close, text=labelTxt,
                               style=label.style_label_left, size=size.small,
                               color=color.new(color.gray, 50), textcolor=color.white)
    else
        label.set_xy(liveLabel, bar_index, close)
        label.set_text(liveLabel, labelTxt)

//=============================
// Impulse cadence status (bottom left)
// Status = live elapsed since last event (updates every bar)
// Last gap shown as context only
//=============================
var table cadence = table.new(position.bottom_left, 1, 2, border_width=2, frame_width=2, frame_color=color.new(color.white, 60))
if barstate.islast and not na(prevImpulseTime)
    elapsedMs  = time - prevImpulseTime
    elapsedMin = math.round(elapsedMs / 60000)
    elHr       = math.floor(elapsedMin / 60)
    elMn       = elapsedMin - elHr * 60
    elStr      = elapsedMin >= 60
                  ? str.tostring(elHr, "#") + "h " + str.tostring(elMn, "#") + "m since last event"
                  : str.tostring(elapsedMin, "#") + "m since last event"

    // Only override to RANGE BOUND when idle too long — otherwise show last event's status
    displayStatus = elapsedMin > slowImpulseMins ? "RANGE BOUND" : lastStatus
    statusStr = displayStatus == "REVERSAL" ? "⟳ REVERSAL" : displayStatus == "DIRECTIONAL" ? "⚡ DIRECTIONAL" : displayStatus == "RANGE BOUND" ? "◈ RANGE BOUND" : displayStatus == "TRENDING" ? "● TRENDING" : "— WAITING"
    statusBg  = displayStatus == "REVERSAL" ? color.new(color.yellow, 10) : displayStatus == "DIRECTIONAL" ? color.new(color.red, 0) : displayStatus == "RANGE BOUND" ? color.new(color.blue, 20) : displayStatus == "TRENDING" ? color.new(color.gray, 40) : color.new(color.gray, 60)

    table.cell(cadence, 0, 0, elStr,     text_size=size.small, text_color=color.white, bgcolor=color.new(color.black, 40))
    table.cell(cadence, 0, 1, statusStr, text_size=size.large,  text_color=color.white, bgcolor=statusBg)

//=============================
// Stats
//=============================
var table stats = table.new(position.top_right, 2, 3, border_width=1)
if barstate.islast
    total = extCount + normCount
    pct   = total > 0 ? str.tostring(math.round(extCount / total * 100)) + "%" : "N/A"
    table.cell(stats, 0, 0, "Type",       text_size=size.small, text_color=color.gray)
    table.cell(stats, 1, 0, "Count",      text_size=size.small, text_color=color.gray)
    table.cell(stats, 0, 1, "Extended",   text_size=size.small, bgcolor=color.new(color.purple,  60))
    table.cell(stats, 1, 1, str.tostring(extCount),  text_size=size.small)
    table.cell(stats, 0, 2, "Normal",     text_size=size.small, bgcolor=color.new(color.fuchsia, 60))
    table.cell(stats, 1, 2, str.tostring(normCount) + "  (" + pct + " ext)", text_size=size.small)

//=============================
// Legend
//=============================
var table legend = table.new(position.bottom_right, 2, 7, border_width=1)
if barstate.islast
    table.cell(legend, 0, 0, "●", bgcolor=color.new(color.blue,    0), text_color=color.white, text_size=size.small)
    table.cell(legend, 1, 0, "Reset (ETH)",         text_size=size.small)
    table.cell(legend, 0, 1, "●", bgcolor=color.new(color.yellow,  0), text_color=color.black, text_size=size.small)
    table.cell(legend, 1, 1, "Reset (Mkt Open)",    text_size=size.small)
    table.cell(legend, 0, 2, "●", bgcolor=color.new(color.green,   0), text_color=color.white, text_size=size.small)
    table.cell(legend, 1, 2, "Impulse Up",           text_size=size.small)
    table.cell(legend, 0, 3, "●", bgcolor=color.new(color.red,     0), text_color=color.white, text_size=size.small)
    table.cell(legend, 1, 3, "Impulse Down",         text_size=size.small)
    table.cell(legend, 0, 4, "●", bgcolor=color.new(color.fuchsia, 0), text_color=color.white, text_size=size.small)
    table.cell(legend, 1, 4, "Anchor (Reversion)",  text_size=size.small)
    table.cell(legend, 0, 5, "●", bgcolor=color.new(color.purple,  0), text_color=color.white, text_size=size.small)
    table.cell(legend, 1, 5, "Extended Anchor",      text_size=size.small)
    table.cell(legend, 0, 6, "●", bgcolor=color.new(color.orange,  0), text_color=color.white, text_size=size.small)
    table.cell(legend, 1, 6, "Loiter Reset",         text_size=size.small)
