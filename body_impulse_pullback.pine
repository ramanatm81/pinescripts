//@version=6
strategy("Body Impulse Pullback", overlay=true, max_labels_count=500,
         default_qty_type=strategy.fixed, default_qty_value=1)

//=============================
// Inputs
//=============================
bodyRTH        = input.float(15.0,  "Min Body Size RTH (points)",         minval=1.0,  step=0.5)
bodyETH        = input.float(10.0,  "Min Body Size ETH (points)",         minval=1.0,  step=0.5)
wickPct        = input.float(50.0,  "Max Wick (% of body)",               minval=5.0,  maxval=200.0, step=5.0)
watchBars      = input.int(12,      "Watch Window (bars)",                 minval=1,    maxval=50)
minPullbackPct = input.float(30.0,  "Min Pull-back (% of body)",          minval=5.0,  maxval=100.0, step=5.0)
stopPts        = input.float(100.0, "Stop Loss (points)",                  minval=1.0,  step=0.5)
tpMult         = input.float(2.0,   "TP multiplier (× ref body)",         minval=0.1,  step=0.1)
flipPct        = input.float(50.0,  "Flip trigger (% drop from high)",    minval=5.0,  maxval=100.0, step=5.0)
nysOpen        = input.bool(false,  "Block NYSE open (09:30 ET, 30 min)")
ldnOpen        = input.bool(false,  "Block LDN open (03:00 ET, 30 min)")

//=============================
// Per-bar body metrics
//=============================
body      = math.abs(close - open)
bodyWhole = math.round(body)
upperWick = high - math.max(open, close)
lowerWick = math.min(open, close) - low
wickLimit = body * (wickPct / 100.0)

etMinsBody = hour(time, "America/New_York") * 60 + minute(time, "America/New_York")
inRTH      = etMinsBody >= 570 and etMinsBody < 960
bodyPts    = inRTH ? bodyRTH : bodyETH

cleanBody  = bodyWhole >= bodyPts and upperWick <= wickLimit and lowerWick <= wickLimit

//=============================
// Session time filter
//=============================
etMins     = etMinsBody
inEodBlock = etMins >= 960 and etMins < 1080
noEntry    = (nysOpen and etMins >= 570 and etMins < 600) or (ldnOpen and etMins >= 180 and etMins < 210) or inEodBlock
hardClose  = (nysOpen and etMins == 565) or (ldnOpen and etMins == 175) or etMins == 225 or etMins == 960

//=============================
// State
//=============================
var int   watchCount    = 0
var float refOpen       = na
var float refClose      = na
var float refBody       = na
var bool  refBull       = false
var bool  pullbackDone  = false   // phase 1 complete — pull-back depth reached
var int   tradeDir      = 0       // 0=flat, 1=long, -1=short
var bool  isFlip        = false   // current trade is a flip (phase 4)
var float bestPrice     = na      // highest high (long) / lowest low (short) since entry

//=============================
// Hard close
//=============================
if hardClose and strategy.position_size != 0
    strategy.close_all(comment="hard close")
    tradeDir    := 0
    isFlip      := false
    bestPrice   := na
    watchCount  := 0

//=============================
// Reference candle detection
//=============================
newRef = cleanBody and watchCount == 0 and tradeDir == 0

if newRef
    watchCount   := watchBars
    refOpen      := open
    refClose     := close
    refBody      := body
    refBull      := close > open
    pullbackDone := false
    label.new(bar_index, refBull ? high : low,
              text      = "REF\n" + str.tostring(body, "#.#") + "pt",
              style     = refBull ? label.style_label_up : label.style_label_down,
              color     = color.new(color.blue, 20),
              textcolor = color.white,
              size      = size.small)

//=============================
// Watch window — pull-back + recovery
//=============================
var bool isCont = false
var bool isRev  = false
isCont := false
isRev  := false

if watchCount > 0 and not newRef and tradeDir == 0
    watchCount -= 1

    pullbackThresh = refBody * (minPullbackPct / 100.0)

    // Phase 1 — wait for minimum pull-back below refClose (bull) / above refClose (bear)
    if not pullbackDone
        if refBull and low <= refClose - pullbackThresh
            pullbackDone := true
        else if not refBull and high >= refClose + pullbackThresh
            pullbackDone := true

    // Phase 2 — pull-back confirmed, wait for recovery above refClose (bull) / below refClose (bear)
    else
        if refBull and close > refClose
            isCont     := true
            watchCount := 0
        else if not refBull and close < refClose
            isCont     := true
            watchCount := 0

    // Window expired with pull-back done but no recovery → silent expiry
    // Window expired with no pull-back → silent expiry

//=============================
// Signal labels
//=============================
if isCont and not noEntry
    label.new(bar_index, refBull ? high : low,
              text      = "CONT",
              style     = refBull ? label.style_label_up : label.style_label_down,
              color     = color.new(color.teal, 10),
              textcolor = color.white,
              size      = size.normal)

//=============================
// Trade entries — Phase 3 (initial CONT)
//=============================
if isCont and tradeDir == 0 and not noEntry
    tpLevel = refBull ? refClose + refBody * tpMult : refClose - refBody * tpMult
    slLevel = refBull ? close - stopPts : close + stopPts
    if refBull
        strategy.entry("Long",  strategy.long,  comment="CONT↑")
        strategy.exit("TP/SL-Long",  "Long",  limit=tpLevel, stop=slLevel)
    else
        strategy.entry("Short", strategy.short, comment="CONT↓")
        strategy.exit("TP/SL-Short", "Short", limit=tpLevel, stop=slLevel)
    tradeDir  := refBull ? 1 : -1
    isFlip    := false
    bestPrice := close
    watchCount := 0

//=============================
// Phase 4 — flip monitoring while in initial trade
//=============================
if tradeDir != 0 and not isFlip and strategy.position_size != 0
    // Track best price
    if tradeDir == 1
        bestPrice := na(bestPrice) ? high : math.max(bestPrice, high)
    else
        bestPrice := na(bestPrice) ? low : math.min(bestPrice, low)

    // Check flip condition
    flipThresh = refBody * (flipPct / 100.0)
    flipTriggered = tradeDir == 1 ? (bestPrice - low >= flipThresh) : (high - bestPrice >= flipThresh)

    if flipTriggered
        strategy.close_all(comment="FLIP")
        flipEntry = close
        tpFlip    = tradeDir == 1 ? flipEntry - refBody * tpMult : flipEntry + refBody * tpMult
        slFlip    = tradeDir == 1 ? flipEntry + refBody * 0.5    : flipEntry - refBody * 0.5
        if tradeDir == 1
            strategy.entry("Short", strategy.short, comment="FLIP↓")
            strategy.exit("TP/SL-Flip", "Short", limit=tpFlip, stop=slFlip)
        else
            strategy.entry("Long",  strategy.long,  comment="FLIP↑")
            strategy.exit("TP/SL-Flip", "Long",  limit=tpFlip, stop=slFlip)
        tradeDir  := tradeDir * -1
        isFlip    := true
        bestPrice := na
        label.new(bar_index, tradeDir == -1 ? high : low,
                  text      = "FLIP",
                  style     = tradeDir == -1 ? label.style_label_down : label.style_label_up,
                  color     = color.new(color.purple, 10),
                  textcolor = color.white,
                  size      = size.normal)

//=============================
// Sync tradeDir on external close (TP or SL hit)
//=============================
if strategy.position_size == 0 and strategy.position_size[1] != 0
    tradeDir  := 0
    isFlip    := false
    bestPrice := na

//=============================
// Exit labels
//=============================
tradeClosed = strategy.position_size == 0 and strategy.position_size[1] != 0
if tradeClosed
    isTP = strategy.netprofit > strategy.netprofit[1]
    if isTP
        label.new(bar_index, low,
                  text      = "TP",
                  style     = label.style_label_up,
                  color     = color.new(color.green, 20),
                  textcolor = color.white,
                  size      = size.small)
    else
        label.new(bar_index, high,
                  text      = "SL",
                  style     = label.style_label_down,
                  color     = color.new(color.red, 20),
                  textcolor = color.white,
                  size      = size.small)

//=============================
// Background tint
//=============================
bgcolor(watchCount > 0 ? color.new(color.yellow, 92) : na, title="Watch Window")

//=============================
// Alerts
//=============================
if isCont and tradeDir == 1
    alert("BIP: LONG entry — CONT↑ at " + str.tostring(close), alert.freq_once_per_bar)
if isCont and tradeDir == -1
    alert("BIP: SHORT entry — CONT↓ at " + str.tostring(close), alert.freq_once_per_bar)
if hardClose
    alert("BIP: HARD CLOSE — session open in 5 min", alert.freq_once_per_bar)
