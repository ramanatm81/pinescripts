//@version=6
// =====================================================================================
// PIVOT RECLAIM  -- range-structure reclaim strategy, for visual eyeballing.
//
// PREMISE: a fractal pivot low = support, pivot high = resistance. When price CROSSES BACK
// UP through support (was below, now closes above), the breakdown FAILED -> uptrend resuming
// -> go LONG. Mirror SHORT: price crosses DOWN through resistance (failed breakout).
//
// This is NOT a fade (buying support hoping for a bounce lost badly, 43% win). It is a
// RECLAIM (join the recovery through the level, 58% win in backtest).
//
// Backtest (mnq 5yr, long-only, TP70/SL50): +3,321 pts / 1pt slip, 43% win, 3/6 yrs.
// Marginal edge -- this Pine is to SEE why trades win/lose, not a shipped strategy.
// Long-only by default (short toggle available; short loses on NQ upward drift).
//
// Pivots: ta.pivotlow/high with srHalfWidth (10 -> 21-bar pivot), same as slope strategy.
// =====================================================================================
strategy("Pivot Reclaim", overlay=true, max_labels_count=500, max_bars_back=5000,
         default_qty_type=strategy.fixed, default_qty_value=1, calc_on_every_tick=false)

//=============================
// Inputs
//=============================
srHalfWidth = input.int(10,   "Fractal half-width (10 = 21-bar pivot)", minval=1, maxval=20, group="Pivots")
enableLong  = input.bool(true,  "Enable LONG (support reclaim, cross UP)",       group="Entry")
enableShort = input.bool(false, "Enable SHORT (resistance reject, cross DOWN)",  group="Entry")
reclaimBuf  = input.float(10.0, "Reclaim buffer (close must cross the level by this many pts)", minval=0.0, step=1.0, group="Entry")
minRange    = input.float(50.0, "Min range width: skip if resistance - support < this (pts)", minval=0.0, step=1.0, group="Entry")
tpPts       = input.float(70.0, "Take Profit (pts) -- used when trail is OFF",  minval=1.0, step=1.0, group="Exit")
slPts       = input.float(50.0, "Stop Loss (pts)",    minval=1.0, step=1.0, group="Exit")
enableTrail = input.bool(true,  "Use trailing profit (replaces fixed TP)", group="Trailing")
trailArm    = input.float(75.0, "Arm trail after this much profit (pts)",   minval=1.0, step=1.0, group="Trailing")
trailGap    = input.float(25.0, "Trail gap behind best price (pts)",        minval=1.0, step=1.0, group="Trailing")
cooldownBars= input.int(10,     "Cooldown bars after an exit", minval=0, maxval=200, group="Exit")

showPivots  = input.bool(true,  "Draw pivot support/resistance lines", group="Display")
showLevels  = input.bool(true,  "Draw live SL/TP lines while in a trade", group="Display")

startDate = input.time(timestamp("2019-01-01 00:00"), "Backtest start", group="Window")
endDate   = input.time(timestamp("2030-01-01 00:00"), "Backtest end",   group="Window")

//=============================
// Continuous rolling OLS slope (legSlope) -- same idiom as slope_strategy.pine
//=============================
lookback = 10
dojiPct  = input.float(10.0, "Doji body % of range (excluded from slope)", minval=1.0, maxval=49.0, step=1.0, group="Slope")
_range   = high - low
_bodyPct = _range > 0.0 ? (math.abs(close - open) / _range) * 100.0 : 0.0
isDoji   = _bodyPct < dojiPct
var float[] slopeBuf = array.new_float(0)
var float   legSlope = na
legSlope := na
if not isDoji
    array.push(slopeBuf, close)
    if array.size(slopeBuf) > lookback
        array.shift(slopeBuf)
if array.size(slopeBuf) == lookback
    n = lookback
    sumX = 0.0
    sumY = 0.0
    sumXY = 0.0
    sumX2 = 0.0
    for i = 0 to n - 1
        x = float(i)
        y = array.get(slopeBuf, i)
        sumX += x
        sumY += y
        sumXY += x * y
        sumX2 += x * x
    denom = n * sumX2 - sumX * sumX
    legSlope := denom != 0.0 ? math.round((n * sumXY - sumX * sumY) / denom, 2) : 0.0

//=============================
// Fractal pivots (support = last pivot low, resistance = last pivot high)
//=============================
_ph = ta.pivothigh(high, srHalfWidth, srHalfWidth)
_pl = ta.pivotlow(low,  srHalfWidth, srHalfWidth)
var float resistance = na
var float support    = na
if not na(_ph)
    resistance := _ph
if not na(_pl)
    support    := _pl

plot(showPivots and not na(resistance) ? resistance : na, "resistance", color=showPivots ? color.new(color.red,   0) : na, linewidth=1, style=plot.style_linebr)
plot(showPivots and not na(support)    ? support    : na, "support",    color=showPivots ? color.new(color.green, 0) : na, linewidth=1, style=plot.style_linebr)

// Range must exist AND be at least minRange wide (skip tight ranges -- not enough room
// between support and resistance for the trade to be worth taking).
_rangeOK = not na(support) and not na(resistance) and (resistance - support) >= minRange

//=============================
// Cooldown + trade state
//=============================
var int cooldown = 0
if cooldown > 0 and strategy.position_size == 0
    cooldown -= 1

inLong  = strategy.position_size > 0
inShort = strategy.position_size < 0

//=============================
// ENTRY -- reclaim = cross THROUGH the level (close-based)
//   LONG : prior close below support, current close back at/above  (failed breakdown)
//   SHORT: prior close above resistance, current close back at/below (failed breakout)
//=============================
canEnter = strategy.position_size == 0 and cooldown == 0 and _rangeOK and time >= startDate and time <= endDate

// Reclaim must clear the level by reclaimBuf pts: prior close was below support, current
// close is at least reclaimBuf ABOVE support (a genuine cross, not a marginal touch).
longReclaim  = enableLong  and canEnter and close[1] < support    and close >= support    + reclaimBuf
shortReject  = enableShort and canEnter and close[1] > resistance and close <= resistance - reclaimBuf

// Track best price per trade (reset on entry) for the trailing stop.
var float bestPrice = na
if longReclaim
    strategy.entry("Long", strategy.long)
    bestPrice := close
if shortReject
    strategy.entry("Short", strategy.short)
    bestPrice := close
if inLong
    bestPrice := na(bestPrice) ? high : math.max(bestPrice, high)
if inShort
    bestPrice := na(bestPrice) ? low : math.min(bestPrice, low)
if strategy.position_size == 0
    bestPrice := na

//=============================
// EXIT
//   Trail ON  : hard SL, then once profit >= trailArm trail trailGap behind best price.
//   Trail OFF : fixed TP / SL.
//=============================
_entry = strategy.position_avg_price
_longArmed  = inLong  and not na(bestPrice) and (bestPrice - _entry) >= trailArm
_shortArmed = inShort and not na(bestPrice) and (_entry - bestPrice) >= trailArm
_longTrail  = (enableTrail and _longArmed)  ? bestPrice - trailGap : na
_shortTrail = (enableTrail and _shortArmed) ? bestPrice + trailGap : na

if inLong
    _stop = na(_longTrail) ? (_entry - slPts) : math.max(_entry - slPts, _longTrail)
    _lim  = enableTrail ? na : (_entry + tpPts)
    strategy.exit("ExitL", from_entry="Long", stop=_stop, limit=_lim)
if inShort
    _stop = na(_shortTrail) ? (_entry + slPts) : math.min(_entry + slPts, _shortTrail)
    _lim  = enableTrail ? na : (_entry - tpPts)
    strategy.exit("ExitS", from_entry="Short", stop=_stop, limit=_lim)

// cooldown after we go flat
if strategy.position_size == 0 and strategy.position_size[1] != 0
    cooldown := cooldownBars

//=============================
// Visual markers
//=============================
// Entry triangles at the reclaim/reject bar.
plotshape(longReclaim, "Long reclaim",  shape.triangleup,   location.belowbar, color=color.new(color.lime, 0), size=size.small, text="RCL")
plotshape(shortReject, "Short reject",  shape.triangledown, location.abovebar, color=color.new(color.red,  0), size=size.small, text="REJ")

// Exit markers colored by reason: was the exit a TP (win) or SL (loss)?
_justFlat = strategy.position_size == 0 and strategy.position_size[1] != 0
_wasLong  = strategy.position_size[1] > 0
_exitPx   = strategy.position_avg_price[1]
_tpHit    = _justFlat and (_wasLong ? high >= _exitPx + tpPts : low <= _exitPx - tpPts)
plotshape(_justFlat and _tpHit,       "TP exit", shape.circle, location.abovebar, color=color.new(color.green, 0), size=size.tiny)
plotshape(_justFlat and not _tpHit,   "SL exit", shape.xcross, location.abovebar, color=color.new(color.red,   0), size=size.tiny)

// Live SL/TP lines while in a trade.
// Upper line = TP (trail off) or the armed trailing stop (trail on); lower = hard SL.
_activeTrail = inLong ? _longTrail : (inShort ? _shortTrail : na)
_tpLine = not showLevels or strategy.position_size == 0 ? na : (enableTrail ? _activeTrail : (inLong ? _entry + tpPts : _entry - tpPts))
_slLine = not showLevels or strategy.position_size == 0 ? na : (inLong ? _entry - slPts : _entry + slPts)
plot(_tpLine, "TP/trail level", color=na(_tpLine) ? na : color.new(color.aqua,   0), linewidth=1, style=plot.style_linebr)
plot(_slLine, "SL level",       color=na(_slLine) ? na : color.new(color.maroon, 0), linewidth=1, style=plot.style_linebr)

// Diagnostics
plot(legSlope,   "legSlope",      color=na, display=display.data_window)
plot(support,    "support px",    color=na, display=display.data_window)
plot(resistance, "resistance px", color=na, display=display.data_window)
plotchar(_rangeOK, "rangeOK", "", location.top, color=na, display=display.data_window)
